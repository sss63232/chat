{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "debugpy",
            "name": "FastAPI: fastapi dev",
            "request": "launch",
            "module": "fastapi",
            "cwd": "${workspaceFolder}",
            "args": [
                "dev",
                "app/main.py",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
