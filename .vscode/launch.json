{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Spring Boot: ChatgptApplication",
      "request": "launch",
      "mainClass": "com.example.chatgpt.ChatgptApplication",
      "projectName": "chatgpt",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "type": "debugpy",
      "name": "FastAPI: uvicorn",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/fastapi_backend",
      "args": [
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/fastapi_backend"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
